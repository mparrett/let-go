(ns test.catch-class-test
  (:require [ir.passes.pipeline :as pipeline]
            [test :refer :all]))

(defn- lower-status [form]
  (binding [pipeline/*target* :go]
    (:status (pipeline/compile-form form))))

(deftest catch-bare-binding
  (testing "let-go's bare (catch e body) still works"
    (is (= :ok (try (throw "boom") (catch e :ok))))))

(deftest catch-with-class-symbol
  (testing "(catch Throwable e body) catches anything thrown, strings included"
    (is (= :ok (try (throw "boom") (catch Throwable e :ok))))
    (is (= :ok (try (throw (ex-info "x" {})) (catch Throwable e :ok)))))

  (testing "other classes dispatch by type: a thrown string is not an Exception"
    (is (= :ok (try (throw (Exception. "boom")) (catch Exception e :ok))))
    (is (= :ok (try (throw (ex-info "x" {})) (catch java.lang.RuntimeException e :ok))))
    (is (= :outer
           (try
             (try (throw "boom") (catch Exception e :inner))
             (catch e :outer)))))

  (testing "binding symbol is still bound to the thrown value"
    (is (= "boom" (try (throw "boom") (catch Throwable e (str e)))))))

(deftest catch-empty-body
  (testing "class + binding with an empty body catches and returns nil"
    (is (nil? (try (throw "boom") (catch Throwable _))))
    (is (nil? (try (throw (Exception. "boom")) (catch Exception _)))))
  (testing "a qualified class let-go does not model never matches"
    ;; (catch java.io.FileNotFoundException _) — no body, dotted class.
    ;; weavejester's integrant uses this form. It must COMPILE (the class
    ;; resolves at dispatch time), and since let-go does not model the
    ;; class, the clause never matches and the throw propagates.
    (is (= :outer
           (try
             (try (throw "boom") (catch java.io.FileNotFoundException _))
             (catch e :outer))))
    (is (= 1 (try 1 (catch java.io.FileNotFoundException _)))))
  (testing "the bare one-body-form still returns that form, not nil"
    (is (= :ok (try (throw "boom") (catch e :ok))))))

(deftest catch-with-finally
  (testing "finally still runs"
    (let [a (atom 0)]
      (try
        (try (throw "x") (catch Throwable e (swap! a inc)) (finally (swap! a inc)))
        (catch e nil))
      (is (= 2 @a)))))

(deftest catch-empty-body-lowers-to-native-go
  (testing "native lowering shares bytecode catch-shape parsing"
    (is (= :lowered
           (lower-status '(defn catch-simple []
                            (try (throw "boom") (catch Throwable _))))))
    (is (= :lowered
           (lower-status '(defn catch-qualified []
                            (try (throw "boom")
                                 (catch java.io.FileNotFoundException _))))))))
