;; Namespace feature tests
(ns test.namespace-test
  (:require [test :refer :all]))

(deftest qualified-access
  (testing "cross-namespace qualified access"
    (is (= 3 (core/+ 1 2)))
    (is (some? (var core/+)))))

(deftest auto-resolve-keyword
  (testing "::keyword auto-resolves to current namespace"
    (is (keyword? ::foo))
    (is (some? (namespace ::foo)))))

(deftest ns-require-as
  (testing "ns with :require :as works"
    ;; core is already required, test alias access
    (is (= 3 (core/+ 1 2)))))

(deftest ns-require-refer-all
  (testing "ns with :refer :all brings in all vars"
    ;; test :refer :all is already used for the test ns
    (is (some? (var is)))
    (is (some? (var testing)))
    (is (some? (var deftest)))))

(deftest ns-name-function
  (testing "current namespace name"
    (is (some? *ns*))))

(deftest intern-preserves-existing-root
  (testing "two-arity intern returns existing var without clearing its root"
    (let [v (intern 'test.namespace-test 'interned-value 42)
          same-v (intern 'test.namespace-test 'interned-value)]
      (is (= 42 (var-get v)))
      (is (= 42 (var-get same-v))))))

(defn ns-pub-fn [x] x)
(def ns-pub-val 99)
(defn- ns-priv-fn [x] x)

(deftest ns-publics-function
  (testing "ns-publics returns a symbol->var map of the public interned vars"
    (let [pubs (ns-publics 'test.namespace-test)]
      (is (contains? pubs 'ns-pub-fn))
      (is (contains? pubs 'ns-pub-val))
      (is (var? (get pubs 'ns-pub-fn)))
      (is (= 99 (deref (get pubs 'ns-pub-val))))))
  (testing "ns-publics excludes private vars"
    (is (not (contains? (ns-publics 'test.namespace-test) 'ns-priv-fn))))
  (testing "ns-publics accepts a namespace object as well as a symbol"
    (is (contains? (ns-publics (the-ns 'test.namespace-test)) 'ns-pub-fn)))
  (testing "ns-publics resolves clojure-facing aliases (clojure.core -> core)"
    (is (contains? (ns-publics 'clojure.core) 'map))
    (is (= (ns-publics 'clojure.core) (ns-publics 'core)))))
