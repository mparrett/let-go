;; Metadata tests: with-meta, meta
(ns test.metadata-test
  (:require [test :refer :all]))

(deftest meta-on-vector
  (testing "with-meta and meta on vector"
    (let [v (with-meta [1 2 3] {:tag :vec})]
      (is (= {:tag :vec} (meta v)))
      (is (= [1 2 3] v)))))

(deftest meta-on-map
  (testing "with-meta and meta on map"
    (let [m (with-meta {:a 1} {:source "test"})]
      (is (= {:source "test"} (meta m)))
      (is (= {:a 1} m)))))

(deftest meta-on-list
  (testing "with-meta and meta on list"
    (let [l (with-meta '(1 2 3) {:type :list})]
      (is (= {:type :list} (meta l)))
      (is (= '(1 2 3) l)))))

(deftest meta-on-set
  (testing "with-meta and meta on set"
    (let [s (with-meta #{1 2 3} {:label :myset})]
      (is (= {:label :myset} (meta s)))
      (is (= #{1 2 3} s)))))

(deftest meta-returns-nil-when-absent
  (testing "meta returns nil when no metadata"
    (is (nil? (meta [1 2 3])))
    (is (nil? (meta {:a 1})))
    (is (nil? (meta '(1 2 3))))
    (is (nil? (meta nil)))
    (is (nil? (meta (fn [x] x))))))

(deftest meta-on-fn
  (testing "with-meta and meta round-trip on a fn, leaving it callable"
    (let [f (with-meta (fn [x] (* x 2)) {:tag :doubler})]
      (is (fn? f))
      (is (= {:tag :doubler} (meta f)))
      (is (= 6 (f 3)))))
  (testing "round-trip works on a variadic fn"
    (let [g (with-meta (fn [& args] (apply + args)) {:kind :sum})]
      (is (= {:kind :sum} (meta g)))
      (is (= 6 (g 1 2 3)))))
  (testing "with-meta returns a copy; the original fn keeps its own metadata"
    (let [f (fn [x] x)
          f1 (with-meta f {:v 1})
          f2 (with-meta f1 {:v 2})]
      (is (nil? (meta f)))
      (is (= {:v 1} (meta f1)))
      (is (= {:v 2} (meta f2)))))
  (testing "round-trip works on a native builtin, leaving the shared original clean"
    (is (= {:tag :plus} (meta (with-meta + {:tag :plus}))))
    (is (= 6 ((with-meta + {:tag :plus}) 1 2 3)))
    (is (nil? (meta +)))))

(defmulti meta-mm identity)
(defmethod meta-mm :a [_] "A")

(deftest meta-on-multifn
  (testing "with-meta round-trips on a multimethod (fn? includes MultiFn)"
    (is (fn? meta-mm))
    (let [m (with-meta meta-mm {:tag :multi})]
      (is (= {:tag :multi} (meta m)))
      (is (= "A" (m :a))))
    (is (nil? (meta meta-mm)))))

(defprotocol MetaProto (mp-op [x]))
(extend-type (type 0) MetaProto (mp-op [_] "int"))

(deftest meta-on-protocol-fn
  (testing "with-meta round-trips on a protocol method fn, leaving dispatch intact"
    (let [m (with-meta mp-op {:tag :proto})]
      (is (= {:tag :proto} (meta m)))
      (is (= "int" (m 7))))
    (is (nil? (meta mp-op)))))

(deftest equality-ignores-metadata
  (testing "equal values with different metadata are still equal"
    (is (= [1 2] (with-meta [1 2] {:x 1})))
    (is (= (with-meta [1 2] {:a 1}) (with-meta [1 2] {:b 2})))
    (is (= {:a 1} (with-meta {:a 1} {:source "test"})))))

(deftest assoc-preserves-metadata
  (testing "assoc preserves metadata on maps and vectors"
    (let [m (with-meta {:a 1} {:source "test"})
          v (with-meta [1] {:tag :vec})]
      (is (= {:source "test"} (meta (assoc m :b 2))))
      (is (= {:tag :vec} (meta (assoc v 0 2))))
      (is (= {:tag :vec} (meta (assoc v 1 3)))))))

(deftest empty-preserves-metadata
  (testing "empty preserves metadata on collections"
    (let [m {:tag :empty}]
      (is (= m (meta (empty (with-meta {:a 1} m)))))
      (is (= m (meta (empty (with-meta [1] m)))))
      (is (= m (meta (empty (with-meta #{1} m)))))
      (is (= m (meta (empty (with-meta '(1) m))))))))

(def ^:dynamic meta-doc-def "def doc" 1)
(defn meta-doc-fn "defn doc" {:added "1.0"} [x] x)
(defn- meta-private-doc-fn "private defn doc" [] :ok)
(defmacro meta-doc-macro "defmacro doc" {:added "3.0"} [x] x)
(defmulti meta-doc-multi "defmulti doc" {:added "2.0"} type)
(defprotocol MetaDocProtocol "protocol doc"
  (meta-doc-op [this] "method doc"))

(deftest var-meta-on-def-forms
  (testing "def attaches doc and reader metadata to the var"
    (is (= "def doc" (:doc (meta (var meta-doc-def)))))
    (is (= true (:dynamic (meta (var meta-doc-def))))))
  (testing "defn attaches doc and attr-map metadata to the var"
    (is (= "defn doc" (:doc (meta (var meta-doc-fn)))))
    (is (= "1.0" (:added (meta (var meta-doc-fn))))))
  (testing "defn- keeps private metadata while adding doc metadata"
    (is (= "private defn doc" (:doc (meta (var meta-private-doc-fn)))))
    (is (= true (:private (meta (var meta-private-doc-fn))))))
  (testing "defmacro attaches doc and attr-map metadata to the var"
    (is (= "defmacro doc" (:doc (meta (var meta-doc-macro)))))
    (is (= "3.0" (:added (meta (var meta-doc-macro))))))
  (testing "defmulti attaches doc and attr-map metadata to the var"
    (is (= "defmulti doc" (:doc (meta (var meta-doc-multi)))))
    (is (= "2.0" (:added (meta (var meta-doc-multi))))))
  (testing "defprotocol attaches protocol and method doc metadata"
    (is (= "protocol doc" (:doc (meta (var MetaDocProtocol)))))
    (is (= "method doc" (:doc (meta (var meta-doc-op)))))))
