(ns test.shuffle-reseq-test
  (:require [test :refer :all]))

;; shuffle must realize lazy seqs before collecting: an empty lazy
;; seq previously produced [nil] instead of [].
(deftest shuffle-empty-lazy-seq
  (testing "empty lazy seq shuffles to []"
    (is (= [] (shuffle (filter odd? [2 4]))))
    (is (empty? (shuffle (filter odd? [2]))))
    (is (= [] (shuffle ()))))

  (testing "lazy seq elements survive"
    (is (= [1 3] (sort (shuffle (filter odd? [1 2 3])))))))

;; re-seq with capture groups yields [full g1 g2 ...] per match,
;; like Clojure; groupless patterns still yield plain strings.
(deftest re-seq-capture-groups
  (testing "groupless patterns yield strings"
    (is (= '("12" "2") (re-seq #"\d+" "12W2B"))))

  (testing "capture groups yield match vectors"
    (is (= '(["12W" "12" "W"] ["2B" "2" "B"])
           (re-seq #"(\d+)(\w)" "12W2B")))
    (is (= '(["ab" "a"]) (re-seq #"(a)b" "ab"))))

  (testing "no match is empty"
    (is (= () (re-seq #"(x)" "abc")))))
